function updateDayCount(){
  const start = new Date('2026-05-20T00:00:00');
  const now = new Date();
  const diffDays = Math.floor((now - start) / (1000*60*60*24));
  document.getElementById('daycount').textContent = diffDays >= 0 ? diffDays : 0;
}
