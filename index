/* Scroll-triggered 3D reveal — replays every time an element enters view */
(function setupScrollReveal(){
  const groups = [
    { selector: '.kicker', cls: 'reveal' },
    { selector: 'section:not(.hero) h2', cls: 'reveal' },
    { selector: '.story-item', cls: 'reveal-rotate' },
    { selector: '.gallery-item', cls: 'reveal-scale' },
    { selector: '.envelope-card', cls: 'reveal-rotate' },
    { selector: '.close-section .card', cls: 'reveal-scale' },
    { selector: '.globe-wrap', cls: 'reveal-scale' },
    { selector: '.env-stage', cls: 'reveal-scale' },
    { selector: '.closing blockquote', cls: 'reveal' },
    { selector: '.closing .heart-btn', cls: 'reveal-scale' }
  ];
  const elements = [];
  groups.forEach(g=>{
    document.querySelectorAll(g.selector).forEach((el, i)=>{
      el.classList.add(g.cls);
      el.style.transitionDelay = Math.min(i * 90, 450) + 'ms';
      elements.push(el);
    });
  });

  if(!('IntersectionObserver' in window)){
    elements.forEach(el => el.classList.add('in-view'));
    return;
  }

  const observer = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      entry.target.classList.toggle('in-view', entry.isIntersecting);
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });

  elements.forEach(el => observer.observe(el));
})();

/* 3D tilt on pointer for cards, gallery, envelopes */
function addTilt(selector){
  document.querySelectorAll(selector).forEach(el=>{
    el.addEventListener('pointermove', (e)=>{
      if(e.pointerType === 'touch') return;
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const rotY = ((x / rect.width) - 0.5) * 14;
      const rotX = (0.5 - (y / rect.height)) * 14;
      el.style.transform = `perspective(700px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-3px)`;
    });
    el.addEventListener('pointerleave', ()=>{ el.style.transform = ''; });
  });
}
addTilt('.gallery-item, .envelope-card, .close-section .card, .clock-card');

/* 3D globe */
(function initGlobe(){
  const wrap = document.getElementById('globeWrap');
  const canvas = document.getElementById('globeCanvas');
  if(!wrap || !canvas || typeof THREE === 'undefined') return;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, wrap.clientWidth / wrap.clientHeight, 0.1, 100);
  camera.position.set(0, 0, 5.2);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias:true, alpha:true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
  renderer.setSize(wrap.clientWidth, wrap.clientHeight);

  const group = new THREE.Group();
  scene.add(group);

  const solidGeo = new THREE.SphereGeometry(1.6, 32, 32);
  const solidMat = new THREE.MeshBasicMaterial({ color: 0x17100f, transparent:true, opacity:0.92 });
  group.add(new THREE.Mesh(solidGeo, solidMat));

  const wireGeo = new THREE.SphereGeometry(1.61, 20, 20);
  const wireMat = new THREE.MeshBasicMaterial({ color: 0xf2a6b8, wireframe:true, transparent:true, opacity:0.32 });
  group.add(new THREE.Mesh(wireGeo, wireMat));

  const starCount = 220;
  const starPos = new Float32Array(starCount * 3);
  for(let i=0;i<starCount;i++){
    const r = 3.2 + Math.random()*2.2;
    const theta = Math.random()*Math.PI*2;
    const phi = Math.acos((Math.random()*2)-1);
    starPos[i*3]   = r*Math.sin(phi)*Math.cos(theta);
    starPos[i*3+1] = r*Math.sin(phi)*Math.sin(theta);
    starPos[i*3+2] = r*Math.cos(phi);
  }
  const starGeo = new THREE.BufferGeometry();
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
  const starMat = new THREE.PointsMaterial({ color:0xc9b7b7, size:0.028, transparent:true, opacity:0.55 });
  scene.add(new THREE.Points(starGeo, starMat));

  function latLongToVec3(lat, lon, r){
    const phi = (90 - lat) * (Math.PI/180);
    const theta = (lon + 180) * (Math.PI/180);
    return new THREE.Vector3(
      -r * Math.sin(phi) * Math.cos(theta),
       r * Math.cos(phi),
       r * Math.sin(phi) * Math.sin(theta)
    );
  }

  const R = 1.62;
  const manilaPos = latLongToVec3(14.6, 120.98, R);
  const calgaryPos = latLongToVec3(51.05, -114.07, R);

  function makeMarker(pos, color){
    const m = new THREE.Mesh(new THREE.SphereGeometry(0.045, 12, 12), new THREE.MeshBasicMaterial({ color }));
    m.position.copy(pos);
    group.add(m);
    return m;
  }
  makeMarker(manilaPos, 0xe63757);
  makeMarker(calgaryPos, 0xf2a6b8);

  const mid = manilaPos.clone().add(calgaryPos).normalize().multiplyScalar(R * 1.55);
  const curve = new THREE.QuadraticBezierCurve3(manilaPos, mid, calgaryPos);
  const arcGeo = new THREE.BufferGeometry().setFromPoints(curve.getPoints(40));
  const arcMat = new THREE.LineDashedMaterial({ color:0xe63757, dashSize:0.06, gapSize:0.04, transparent:true, opacity:0.95 });
  const arcLine = new THREE.Line(arcGeo, arcMat);
  arcLine.computeLineDistances();
  group.add(arcLine);

  group.rotation.y = -0.6;
  group.rotation.x = 0.15;

  let isDragging = false, autoRotate = true, prevX = 0, prevY = 0, resumeTimer = null;

  function onDown(e){
    isDragging = true; autoRotate = false;
    prevX = e.clientX; prevY = e.clientY;
    if(resumeTimer) clearTimeout(resumeTimer);
  }
  function onMove(e){
    if(!isDragging) return;
    const dx = e.clientX - prevX, dy = e.clientY - prevY;
    group.rotation.y += dx * 0.005;
    group.rotation.x = Math.max(-1.1, Math.min(1.1, group.rotation.x + dy * 0.005));
    prevX = e.clientX; prevY = e.clientY;
  }
  function onUp(){
    isDragging = false;
    resumeTimer = setTimeout(()=>{ autoRotate = true; }, 2200);
  }
  wrap.addEventListener('pointerdown', onDown);
  window.addEventListener('pointermove', onMove);
  window.addEventListener('pointerup', onUp);

  const labelPH = document.getElementById('labelPH');
  const labelYYC = document.getElementById('labelYYC');
  function updateLabel(el, worldPos){
    const v = worldPos.clone().applyMatrix4(group.matrixWorld).project(camera);
    el.style.left = ((v.x*0.5+0.5) * wrap.clientWidth) + 'px';
    el.style.top = ((-v.y*0.5+0.5) * wrap.clientHeight) + 'px';
    el.style.opacity = v.z < 0.98 ? '1' : '0.12';
  }

  function animate(){
    requestAnimationFrame(animate);
    if(autoRotate) group.rotation.y += 0.0022;
    group.updateMatrixWorld();
    updateLabel(labelPH, manilaPos);
    updateLabel(labelYYC, calgaryPos);
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', ()=>{
    const w = wrap.clientWidth, h = wrap.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });
})();

/* Heart button petal burst */
const heartBtn = document.getElementById('heartBtn');
const petals = ['♥','❀','✿'];
heartBtn.addEventListener('click', ()=>{
  heartBtn.classList.remove('beat');
  void heartBtn.offsetWidth;
  heartBtn.classList.add('beat');

  const rect = heartBtn.getBoundingClientRect();
  const originX = rect.left + rect.width/2;
  const originY = rect.top + rect.height/2;

  for(let i=0; i<14; i++){
    const p = document.createElement('div');
    p.className = 'petal';
    p.textContent = petals[Math.floor(Math.random()*petals.length)];
    const angle = (Math.random()*Math.PI) + Math.PI;
    const dist = 60 + Math.random()*140;
    const dx = Math.cos(angle)*dist;
    const dy = Math.sin(angle)*dist - 40;
    const rot = (Math.random()*360)-180;
    p.style.left = originX + 'px';
    p.style.top = originY + 'px';
    p.style.color = Math.random() > 0.5 ? 'var(--crimson-bright)' : 'var(--rose)';
    document.body.appendChild(p);

    p.animate([
      { transform:'translate(0,0) rotate(0deg) scale(0.6)', opacity:1 },
      { transform:`translate(${dx}px, ${dy - 120}px) rotate(${rot}deg) scale(1)`, opacity:0 }
    ], { duration: 900 + Math.random()*500, easing:'cubic-bezier(.2,.7,.3,1)' }).onfinish = ()=> p.remove();
  }
});
