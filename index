  transition: opacity 0.2s ease;
}
@media (max-width: 640px){
  .globe-wrap{ height:300px; }
}

/* ---------- LETTERS ---------- */
.letters-section{ border-top:1px solid var(--line); }
.envelope-grid{
  margin-top:44px;
  display:grid;
  grid-template-columns: repeat(2, 1fr);
