<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cheers to Our 2nd Month Together, My Love!</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400;1,500&family=Manrope:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap');

:root{
  --black: #0B0607;
  --black-2: #17100F;
  --black-3: #221718;
  --crimson: #C41E3A;
  --crimson-bright: #E63757;
  --rose: #F2A6B8;
  --blush: #F7DCE2;
  --cream: #F5ECEA;
  --cream-dim: #C9B7B7;
  --line: rgba(245,236,234,0.14);
}

*{box-sizing:border-box; margin:0; padding:0;}
html{scroll-behavior:smooth;}
body{
  background: var(--black);
  color: var(--cream);
  font-family: 'Manrope', sans-serif;
  overflow-x: hidden;
}
@media (prefers-reduced-motion: reduce){
  *{animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important;}
}

a{color:inherit;}
:focus-visible{outline:2px solid var(--crimson-bright); outline-offset:3px;}
button{ font-family:inherit; cursor:pointer; }

.wrap{max-width:1000px; margin:0 auto; padding:0 28px; perspective:1200px;}

/* ---------- HERO ---------- */
.hero{
  position:relative;
  min-height:100svh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding: 90px 24px 60px;
  background:
    radial-gradient(ellipse 65% 45% at 20% 8%, rgba(196,30,58,0.22), transparent 60%),
    radial-gradient(ellipse 65% 45% at 85% 92%, rgba(242,166,184,0.14), transparent 60%),
    var(--black);
}

.eyebrow{
  font-family:'Space Mono', monospace;
  font-size:12.5px;
  letter-spacing:0.16em;
  text-transform:uppercase;
  color: var(--cream-dim);
  margin-bottom:22px;
  display:flex;
  align-items:center;
  gap:10px;
}
.eyebrow .dot{
  width:6px; height:6px; border-radius:50%;
  background:var(--crimson-bright);
  animation: pulse 2.2s ease-in-out infinite;
}
@keyframes pulse{
  0%,100%{ opacity:1; box-shadow:0 0 0 0 rgba(230,55,87,0.55);}
  50%{ opacity:0.65; box-shadow:0 0 0 6px rgba(230,55,87,0);}
}

h1.title{
  font-family:'Fraunces', serif;
  font-weight:600;
  font-size: clamp(2rem, 6.2vw, 3.6rem);
  line-height: 1.08;
  letter-spacing:-0.01em;
  max-width: 780px;
}
h1.title em{
  font-style:italic;
  font-weight:500;
  background: linear-gradient(100deg, var(--crimson-bright), var(--rose));
  -webkit-background-clip:text;
  background-clip:text;
  color:transparent;
}

.hero-sub{
  margin-top:20px;
  max-width:480px;
  font-size:1.02rem;
  line-height:1.6;
  color: var(--cream-dim);
}

/* ---------- CLOCKS ---------- */
.clocks{
  margin-top:56px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:0;
  width:100%;
  max-width:620px;
  flex-wrap:wrap;
}
.clock-card{
  background: var(--black-2);
  border:1px solid var(--line);
  border-radius:18px;
  padding:22px 26px;
  min-width:210px;
  flex:1;
  position:relative;
  transition: border-color 0.3s ease, transform 0.3s ease;
}
.clock-card:hover{ border-color: rgba(230,55,87,0.4); transform: translateY(-2px); }
.clock-card .place{
  font-family:'Space Mono', monospace;
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color: var(--cream-dim);
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.clock-card .who{
  font-family:'Fraunces', serif;
  font-style:italic;
  font-size:0.95rem;
  color: var(--rose);
  margin-top:2px;
}
.clock-card .time{
  font-family:'Space Mono', monospace;
  font-size: clamp(1.8rem, 5vw, 2.4rem);
  font-weight:700;
  margin-top:14px;
  letter-spacing:0.01em;
  color: var(--crimson-bright);
}
.clock-card .daypart{
  margin-top:6px;
  font-size:12.5px;
  color: var(--cream-dim);
}

.signal{
  width:54px;
  height:2px;
  background: repeating-linear-gradient(90deg, var(--cream-dim) 0 6px, transparent 6px 12px);
  position:relative;
  flex-shrink:0;
  align-self:center;
  margin: 18px 0;
}
.signal::before, .signal::after{
  content:'';
  position:absolute;
  top:50%; transform:translateY(-50%);
  width:7px; height:7px;
  border-radius:50%;
  background: var(--crimson-bright);
}
.signal::before{ left:-3px; }
.signal::after{ right:-3px; background: var(--rose); }

.together{
  margin-top:26px;
  font-family:'Space Mono', monospace;
  font-size:13px;
  color: var(--cream-dim);
  letter-spacing:0.03em;
}
.together strong{ color:var(--cream); font-weight:700;}

.scroll-cue{
  position:absolute;
  bottom:30px;
  font-size:11px;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color: var(--cream-dim);
  font-family:'Space Mono', monospace;
}

/* ---------- SECTION SHELL ---------- */
section{ padding: 100px 0; }
.kicker{
  font-family:'Space Mono', monospace;
  font-size:12px;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color: var(--crimson-bright);
  margin-bottom:14px;
}
h2{
  font-family:'Fraunces', serif;
  font-weight:600;
  font-size: clamp(1.9rem, 4.5vw, 2.8rem);
  max-width:640px;
  line-height:1.15;
}

/* ---------- STORY ---------- */
.story{ border-top:1px solid var(--line); }
.story-list{ margin-top:56px; display:flex; flex-direction:column; }
.story-item{
  display:grid;
  grid-template-columns: 150px 1fr;
  gap:28px;
  padding: 34px 0;
  border-top:1px solid var(--line);
  transition: background 0.3s ease;
}
.story-item:hover{ background: rgba(196,30,58,0.05); }
.story-item:last-child{ border-bottom:1px solid var(--line); }
.story-tag{
  font-family:'Space Mono', monospace;
  font-size:11.5px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color: var(--rose);
  padding-top:4px;
}
.story-item h3{
  font-family:'Fraunces', serif;
  font-weight:600;
  font-style:italic;
  font-size:1.35rem;
  margin-bottom:10px;
  color: var(--cream);
}
.story-item p{
  color: var(--cream-dim);
  line-height:1.7;
  font-size:0.98rem;
  max-width:560px;
}

/* ---------- GALLERY ---------- */
.gallery-section{ border-top:1px solid var(--line); }
.gallery-hint{
  margin-top:10px;
  font-family:'Space Mono', monospace;
  font-size:12px;
  color: var(--cream-dim);
}
.gallery{
  margin-top:44px;
  display:grid;
  grid-template-columns: repeat(4, 1fr);
  gap:14px;
}
.gallery-item{
  position:relative;
  border-radius:14px;
  overflow:hidden;
  aspect-ratio: 3/4;
  border:1px solid var(--line);
  background: var(--black-2);
  cursor: zoom-in;
  padding:0;
}
.gallery-item img{
  width:100%; height:100%;
  object-fit:cover;
  display:block;
  transition: transform 0.5s ease, filter 0.5s ease;
  filter: saturate(0.92);
}
.gallery-item:hover img{ transform: scale(1.06); filter: saturate(1.05); }
.gallery-item .cap{
  position:absolute;
  left:0; right:0; bottom:0;
  padding:16px 14px 12px;
  background: linear-gradient(0deg, rgba(0,0,0,0.75), transparent);
  font-family:'Space Mono', monospace;
  font-size:10.5px;
  letter-spacing:0.04em;
  text-align:left;
  color: var(--blush);
  opacity:0;
  transform: translateY(6px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.gallery-item:hover .cap, .gallery-item:focus-visible .cap{ opacity:1; transform:translateY(0); }

/* Lightbox */
.lightbox{
  position:fixed; inset:0;
  background: rgba(6,3,3,0.92);
  display:flex; align-items:center; justify-content:center;
  z-index:100;
  padding: 40px 20px;
  opacity:0; pointer-events:none;
  transition: opacity 0.25s ease;
}
.lightbox.open{ opacity:1; pointer-events:auto; }
.lightbox img{
  max-width:min(560px, 90vw);
  max-height:78vh;
  border-radius:12px;
  box-shadow: 0 30px 80px rgba(0,0,0,0.6);
}
.lightbox-cap{
  position:absolute;
  bottom:60px;
  left:0; right:0;
  text-align:center;
  font-family:'Space Mono', monospace;
  font-size:12px;
  letter-spacing:0.06em;
  color: var(--blush);
}
.lightbox-close{
  position:absolute;
  top:24px; right:24px;
  background:none; border:1px solid var(--line);
  color: var(--cream);
  width:40px; height:40px;
  border-radius:50%;
  font-size:18px;
  display:flex; align-items:center; justify-content:center;
}
.lightbox-close:hover{ border-color: var(--crimson-bright); color: var(--crimson-bright); }

/* ---------- HOW WE STAY CLOSE ---------- */
.close-section{ border-top:1px solid var(--line); }
.cards{
  margin-top:52px;
  display:grid;
  grid-template-columns: repeat(3, 1fr);
  gap:18px;
}
.card{
  background: var(--black-2);
  border:1px solid var(--line);
  border-radius:16px;
  padding:28px 24px;
  transition: transform 0.3s ease, border-color 0.3s ease;
}
.card:hover{ transform: translateY(-4px); border-color: rgba(230,55,87,0.35); }
.card .glyph{
  width:34px; height:34px;
  border-radius:50%;
  border:1px solid var(--line);
  display:flex; align-items:center; justify-content:center;
  font-family:'Space Mono', monospace;
  font-size:13px;
  color: var(--crimson-bright);
  margin-bottom:18px;
}
.card h3{
  font-family:'Fraunces', serif;
  font-weight:600;
  font-size:1.1rem;
  margin-bottom:8px;
}
.card p{
  color: var(--cream-dim);
  font-size:0.92rem;
  line-height:1.6;
}

@media (max-width: 820px){
  .gallery{ grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 720px){
  .cards{ grid-template-columns:1fr; }
  .story-item{ grid-template-columns: 1fr; gap:8px; }
  .clocks{ gap:14px; }
  .signal{ width:2px; height:34px; background: repeating-linear-gradient(180deg, var(--cream-dim) 0 6px, transparent 6px 12px); margin:0;}
  .signal::before{ left:50%; top:-3px; transform:translateX(-50%);}
  .signal::after{ left:50%; top:auto; bottom:-3px; transform:translateX(-50%);}
}

/* ---------- CLOSING ---------- */
.closing{
  border-top:1px solid var(--line);
  text-align:center;
  padding: 110px 24px 90px;
  position:relative;
  overflow:hidden;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(196,30,58,0.14), transparent 65%),
    var(--black);
}
.closing .kicker{ justify-content:center; display:flex; }
.closing blockquote{
  font-family:'Fraunces', serif;
  font-style:italic;
  font-weight:500;
  font-size: clamp(1.5rem, 4vw, 2.3rem);
  max-width:640px;
  margin:0 auto;
  line-height:1.4;
  color: var(--cream);
}
.closing .sign{
  margin-top:30px;
  font-family:'Space Mono', monospace;
  font-size:12.5px;
  letter-spacing:0.08em;
  color: var(--cream-dim);
  text-transform:uppercase;
}
.heart-btn{
  margin-top:36px;
  background: none;
  border:1px solid var(--line);
  color: var(--rose);
  width:56px; height:56px;
  border-radius:50%;
  font-size:22px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  transition: transform 0.15s ease, border-color 0.3s ease, background 0.3s ease;
  position:relative;
  z-index:2;
}
.heart-btn:hover{ border-color: var(--crimson-bright); background: rgba(196,30,58,0.12); }
.heart-btn:active{ transform: scale(0.9); }
.heart-btn.beat{ animation: beat 0.5s ease; }
@keyframes beat{
  0%{ transform:scale(1); }
  30%{ transform:scale(1.25); }
  60%{ transform:scale(0.95); }
  100%{ transform:scale(1); }
}
.heart-hint{
  margin-top:12px;
  font-family:'Space Mono', monospace;
  font-size:10.5px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color: var(--cream-dim);
}
.petal{
  position:fixed;
  top:0;
  font-size:16px;
  pointer-events:none;
  z-index:5;
  will-change: transform, opacity;
}

/* ---------- FLOATING BACKGROUND ---------- */
.floaters{
  position:fixed;
  inset:0;
  z-index:3;
  pointer-events:none;
  overflow:hidden;
}
.float-item{
  position:absolute;
  bottom:-60px;
  opacity:0;
  will-change: transform, opacity;
  animation-name: floatUp;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  filter: drop-shadow(0 0 6px rgba(196,30,58,0.15));
}
@keyframes floatUp{
  0%{ transform: translate(0,0) rotate(0deg); opacity:0; }
  8%{ opacity: var(--op, 0.5); }
  50%{ transform: translate(var(--drift, 30px), -58vh) rotate(var(--rot, 90deg)); }
  92%{ opacity: var(--op, 0.5); }
  100%{ transform: translate(calc(var(--drift, 30px) * 2), -118vh) rotate(calc(var(--rot, 90deg) * 2)); opacity:0; }
}

/* ---------- QUOTE MARQUEE ---------- */
.marquee-section{
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  padding: 34px 0;
  overflow:hidden;
  white-space:nowrap;
  background: var(--black-2);
}
.marquee-track{
  display:inline-flex;
  align-items:center;
  animation: scrollLeft 26s linear infinite;
}
.marquee-track span{
  font-family:'Fraunces', serif;
  font-style:italic;
  font-weight:500;
  font-size: clamp(1.1rem, 2.6vw, 1.6rem);
  color: var(--rose);
  padding: 0 28px;
  white-space:nowrap;
}
.marquee-track span.sep{
  color: var(--crimson-bright);
  font-family:'Manrope', sans-serif;
  font-style:normal;
}
@keyframes scrollLeft{
  from{ transform: translateX(0); }
  to{ transform: translateX(-50%); }
}

/* ---------- CALLS GALLERY (phone-shaped) ---------- */
.calls-section{ border-top:1px solid var(--line); }
.calls-grid{
  margin-top:44px;
  display:grid;
  grid-template-columns: repeat(4, 1fr);
  gap:14px;
}
.calls-grid .gallery-item{ aspect-ratio: 9/16; }

/* ---------- LIGHTBOX NAV ---------- */
.lightbox-nav{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  background:none;
  border:1px solid var(--line);
  color: var(--cream);
  width:44px; height:44px;
  border-radius:50%;
  font-size:18px;
  display:flex; align-items:center; justify-content:center;
  transition: border-color 0.2s ease, color 0.2s ease;
}
.lightbox-nav:hover{ border-color: var(--crimson-bright); color: var(--crimson-bright); }
.lightbox-nav.prev{ left: 18px; }
.lightbox-nav.next{ right: 18px; }
@media (max-width: 600px){
  .lightbox-nav{ width:38px; height:38px; font-size:15px; }
  .lightbox-nav.prev{ left:6px; }
  .lightbox-nav.next{ right:6px; }
}

/* ---------- FLIP CLOCK NOTE ---------- */
.clock-card{ cursor:pointer; perspective: 800px; }
.clock-card .card-inner{
  position:relative;
  min-height:112px;
}
.clock-card .card-face{
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.clock-card .card-note{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  font-family:'Fraunces', serif;
  font-style:italic;
  font-size:1.05rem;
  color: var(--rose);
  opacity:0;
  transform: rotateY(90deg);
  transition: opacity 0.35s ease, transform 0.35s ease;
  padding: 0 8px;
}
.clock-card.flipped .card-face{ opacity:0; transform: rotateY(-90deg); }
.clock-card.flipped .card-note{ opacity:1; transform: rotateY(0deg); }
.clock-tap-hint{
  margin-top:14px;
  font-family:'Space Mono', monospace;
  font-size:10px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color: var(--cream-dim);
  opacity:0.7;
}

/* ---------- HERO AIRPLANE ---------- */
.clocks{ position:relative; }
.hero-plane{
  position:absolute;
  top:50%;
  left:6%;
  font-size:20px;
  transform: translateY(-50%);
  animation: planeFlyH 6s ease-in-out infinite;
  pointer-events:none;
  z-index:2;
  filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
}
@keyframes planeFlyH{
  0%{ left:6%; transform: translateY(-50%) scaleX(1); }
  46%{ left:88%; transform: translateY(-50%) scaleX(1); }
  50%{ left:88%; transform: translateY(-50%) scaleX(-1); }
  96%{ left:6%; transform: translateY(-50%) scaleX(-1); }
  100%{ left:6%; transform: translateY(-50%) scaleX(1); }
}
@media (max-width: 720px){
  .hero-plane{
    left:50%;
    top:8%;
    animation-name: planeFlyV;
    transform: translateX(-50%) rotate(90deg);
  }
  @keyframes planeFlyV{
    0%{ top:8%; transform: translateX(-50%) rotate(90deg); }
    46%{ top:88%; transform: translateX(-50%) rotate(90deg); }
    50%{ top:88%; transform: translateX(-50%) rotate(-90deg); }
    96%{ top:8%; transform: translateX(-50%) rotate(-90deg); }
    100%{ top:8%; transform: translateX(-50%) rotate(90deg); }
  }
}

/* ---------- AMBIENT SKY PLANE ---------- */
.sky-plane{
  position:fixed;
  top:6%;
  left:-8%;
  font-size:22px;
  z-index:3;
  pointer-events:none;
  opacity:0.55;
  animation: skyCross 22s linear infinite;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
}
@keyframes skyCross{
  0%{ left:-8%; top:6%; transform: rotate(8deg); }
  50%{ left:60%; top:2%; transform: rotate(4deg); }
  100%{ left:112%; top:9%; transform: rotate(8deg); }
}

/* ---------- FLIP CARDS (how we stay close) ---------- */
.card{ perspective: 900px; cursor:pointer; }
.card .flip-inner{
  position:relative;
  min-height:150px;
}
.card .flip-face{
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.card .flip-back{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  font-family:'Fraunces', serif;
  font-style:italic;
  font-size:1rem;
  color: var(--rose);
  opacity:0;
  transform: rotateY(90deg);
  transition: opacity 0.35s ease, transform 0.35s ease;
  padding: 0 6px;
}
.card.flipped .flip-face{ opacity:0; transform: rotateY(-90deg); }
.card.flipped .flip-back{ opacity:1; transform: rotateY(0deg); }
.card-flip-hint{
  margin-top:12px;
  text-align:center;
  font-family:'Space Mono', monospace;
  font-size:10px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color: var(--cream-dim);
  opacity:0.7;
}

/* ---------- 3D GLOBE ---------- */
.globe-section{ border-top:1px solid var(--line); text-align:center; }
.globe-section h2{ margin:0 auto; }
.globe-wrap{
  position:relative;
  width:100%;
  max-width:420px;
  aspect-ratio: 1/1;
  margin: 44px auto 0;
  cursor: grab;
  touch-action: none;
}
.globe-wrap:active{ cursor: grabbing; }
.globe-wrap canvas{
  width:100% !important;
  height:100% !important;
  display:block;
}
.globe-legend{
  display:flex;
  justify-content:center;
  gap:26px;
  margin-top:22px;
  font-family:'Space Mono', monospace;
  font-size:11.5px;
  letter-spacing:0.06em;
  color: var(--cream-dim);
}
.globe-legend span{ display:inline-flex; align-items:center; gap:8px; }
.dotmark{ width:8px; height:8px; border-radius:50%; display:inline-block; }
.dotmark.ph{ background: var(--crimson-bright); }
.dotmark.cg{ background: var(--rose); }
.globe-hint{
  margin-top:10px;
  font-family:'Space Mono', monospace;
  font-size:10.5px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color: var(--cream-dim);
  opacity:0.7;
}

/* ---------- SCROLL REVEAL (3D) ---------- */
.reveal{
  opacity:0;
  transform: translateY(46px) rotateX(-18deg);
  transition: opacity 0.7s cubic-bezier(.2,.7,.3,1), transform 0.7s cubic-bezier(.2,.7,.3,1);
  will-change: transform, opacity;
}
.reveal.in-view{ opacity:1; transform: translateY(0) rotateX(0deg); }

.reveal-rotate{
  opacity:0;
  transform: translateY(24px) rotateY(-28deg) scale(0.92);
  transition: opacity 0.65s ease, transform 0.65s cubic-bezier(.2,.7,.3,1);
  will-change: transform, opacity;
}
.reveal-rotate.in-view{ opacity:1; transform: translateY(0) rotateY(0deg) scale(1); }

.reveal-scale{
  opacity:0;
  transform: translateY(20px) scale(0.88) rotateX(10deg);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(.2,.7,.3,1);
  will-change: transform, opacity;
}
.reveal-scale.in-view{ opacity:1; transform: translateY(0) scale(1) rotateX(0deg); }

/* ---------- MONTHSARY ENVELOPE ---------- */
.monthsary-section{ border-top:1px solid var(--line); text-align:center; }
.monthsary-section h2{ margin-left:auto; margin-right:auto; }
.env-stage{
  position:relative;
  margin: 56px auto 0;
  display:flex;
  align-items:center;
  justify-content:center;
  min-height:340px;
  max-width:520px;
  perspective: 1400px;
}
.fluffy{
  position:absolute;
  font-size:30px;
  animation: fluffBob 4.5s ease-in-out infinite;
  filter: drop-shadow(0 6px 10px rgba(0,0,0,0.35));
  pointer-events:none;
  z-index:1;
}
.fluffy.f1{ top:4%; left:6%; animation-delay:0s; font-size:34px; }
.fluffy.f2{ top:8%; right:8%; animation-delay:0.8s; font-size:28px; }
.fluffy.f3{ bottom:8%; left:10%; animation-delay:1.6s; font-size:26px; }
.fluffy.f4{ bottom:6%; right:6%; animation-delay:2.3s; font-size:32px; }
@keyframes fluffBob{
  0%,100%{ transform: translateY(0) rotate(-4deg); }
  50%{ transform: translateY(-14px) rotate(4deg); }
}

.env3d{
  position:relative;
  width:260px;
  height:180px;
  cursor:pointer;
  transform-style: preserve-3d;
  animation: envFloat 5s ease-in-out infinite;
}
.env3d:focus-visible{ outline: 2px solid var(--crimson-bright); outline-offset:6px; }
@keyframes envFloat{
  0%,100%{ transform: translateY(0) rotateZ(0deg); }
  50%{ transform: translateY(-8px) rotateZ(-1deg); }
}
.env3d-pocket{
  position:absolute;
  inset:0;
  background: linear-gradient(160deg, var(--blush), #f0bcc8);
  border-radius:10px;
  box-shadow: 0 22px 50px rgba(0,0,0,0.45);
  z-index:2;
  clip-path: polygon(0 100%, 0 22%, 50% 55%, 100% 22%, 100% 100%);
}
.env3d-flap{
  position:absolute;
  top:0; left:0; right:0;
  height:100%;
  transform-origin: top center;
  z-index:4;
  transition: transform 0.9s cubic-bezier(.3,.7,.3,1);
  clip-path: polygon(0 0, 100% 0, 50% 62%);
  background: linear-gradient(200deg, #f0bcc8, var(--rose));
  box-shadow: inset 0 -6px 14px rgba(0,0,0,0.12);
}
.env3d.open .env3d-flap{ transform: rotateX(180deg); z-index:1; }
.env3d-seal{
  position:absolute;
  top:30%;
  left:50%;
  transform: translate(-50%,-50%);
  width:38px; height:38px;
  border-radius:50%;
  background: var(--crimson);
  color: var(--blush);
  display:flex; align-items:center; justify-content:center;
  font-family:'Fraunces', serif;
  font-style:italic;
  font-weight:700;
  font-size:16px;
  z-index:5;
  box-shadow: 0 6px 16px rgba(196,30,58,0.5);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.env3d.open .env3d-seal{ opacity:0; transform: translate(-50%,-50%) scale(0.4); }
.env3d-card{
  position:absolute;
  left:8%;
  right:8%;
  bottom:14%;
  height:70%;
  background: var(--cream);
  border-radius:8px;
  box-shadow: 0 10px 26px rgba(0,0,0,0.35);
  z-index:3;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:16px;
  transform: translateY(0);
  transition: transform 0.7s cubic-bezier(.2,.7,.3,1) 0.15s;
  cursor:pointer;
}
.env3d.open .env3d-card{ transform: translateY(-92%); z-index:6; }
.env3d-card-front p{
  font-family:'Fraunces', serif;
  font-style:italic;
  color:#241014;
  font-size:0.85rem;
  line-height:1.5;
}
.env3d-card-heart{
  font-size:20px;
  color: var(--crimson);
  margin-bottom:6px;
}
.env-hint{
  margin-top:22px;
  font-family:'Space Mono', monospace;
  font-size:11px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color: var(--cream-dim);
}

/* ---------- GLOBE ---------- */
.globe-section{ border-top:1px solid var(--line); }
.globe-wrap{
  position:relative;
  margin-top:44px;
  width:100%;
  height:380px;
  border:1px solid var(--line);
  border-radius:18px;
  background:
    radial-gradient(ellipse 60% 55% at 50% 30%, rgba(196,30,58,0.14), transparent 70%),
    var(--black-2);
  overflow:hidden;
  touch-action:none;
  cursor:grab;
}
.globe-wrap:active{ cursor:grabbing; }
.globe-wrap canvas{ display:block; width:100%; height:100%; }
.globe-label{
  position:absolute;
  font-family:'Space Mono', monospace;
  font-size:10.5px;
  letter-spacing:0.05em;
  color: var(--blush);
  background: rgba(11,6,7,0.65);
  padding:4px 10px;
  border-radius:20px;
  pointer-events:none;
  transform: translate(-50%, -160%);
